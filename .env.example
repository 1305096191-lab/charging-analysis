# ==========================================
# 实时订单数据分析系统 — 环境配置（示例）
# 复制此文件为 .env 并填入实际值
# ==========================================

# 企业后台 API 基地址
API_BASE_URL=https://sms.rhecube.com

# 登录接口路径
LOGIN_PATH=/api/jupiter-auth-server/login/phone/password

# 订单数据接口路径
ORDER_PATH=/api/ecube-manage-server/ecube/manage/station/order/get/order/data/permit

# 登录凭证（请替换为实际值）
USERNAME=your_phone_number
PASSWORD=your_password

# Bearer Token（手动填写或登录后自动写入）
BEARER_TOKEN=

# 服务端口
PORT=3000

# 数据库文件路径
DB_PATH=./data/orders.db

# 日志目录
LOG_DIR=./logs

# 同步间隔（分钟）
SYNC_INTERVAL_MINUTES=30
